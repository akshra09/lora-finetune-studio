# ─────────────────────────────────────────────────────────────
# LoRA Fine-Tuning Studio — Environment Variables
# Copy this file to app/.env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Your HuggingFace API token (Read permission is enough)
# Get it at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=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

# ── Optional ──────────────────────────────────────────────────

# Your fine-tuned LoRA model repo ID (username/model-name)
# If not set, the UI defaults to TinyLlama-1.1B
DEFAULT_MODEL_ID=YOUR_HF_USERNAME/your-lora-model

# Exposed to the browser (public prefix required for Next.js)
NEXT_PUBLIC_DEFAULT_MODEL=YOUR_HF_USERNAME/your-lora-model
